<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zeroxn.blog.mapper.ArticleTagMapper">
    <select id="getTagByArticleNum" resultType="integer">
        select count(id) from tb_article_tag where tag_id = #{tagId}
    </select>
    <select id="getTagIdListByArticleId" resultType="integer">
        select tag_id from tb_article_tag where article_id = #{articleId}
    </select>
    <select id="getArticleIdListByTagId" resultType="integer">
        select article_id from tb_article_tag where tag_id = #{tagId}
    </select>
    <insert id="saveArticleTagList">
        insert into tb_article_tag(article_id, tag_id) values
        <foreach collection="articleTagList" item="tag" separator=",">
            (#{tag.articleId}, #{tag.tagId})
        </foreach>
    </insert>
    <delete id="deleteArticleTagByArticleId">
        delete from tb_article_tag where article_id = #{articleId}
    </delete>
</mapper>