<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zeroxn.blog.mapper.TagMapper">
    <select id="getTagList" resultType="Tag">
        select * from tb_tag
        <if test="status != null">
            where status = #{status}
        </if>
        order by create_time
    </select>
    <insert id="addTag">
        insert into tb_tag(name, create_time) values (#{name}, #{createTime})
    </insert>
    <update id="updateTagStatus">
        update tb_tag set status = #{status} where id = #{id}
    </update>
    <delete id="deleteTag">
        delete from tb_tag where id = #{id}
    </delete>
    <resultMap id="TagBashMap" type="Tag">
        <id column="id" property="id"/>
        <result column="name" property="name" />
    </resultMap>
    <select id="getTagListByIdList" resultMap="TagBashMap">
        select id, name from tb_tag where id in
        <foreach collection="tagIdList" item="tagId" separator="," open="(" close=")">
            #{tagId}
        </foreach>
        and status = 1;
    </select>
    <select id="getTagListForIdAndName" resultType="Tag">
        select id, name from tb_tag where status = 1;
    </select>
</mapper>