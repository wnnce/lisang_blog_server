<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zeroxn.blog.mapper.ArticleCategoryMapper">
    <select id="getCategoryByArticleNum" resultType="integer">
        select count(id) from tb_article_category where category_id = #{categoryId}
    </select>
    <select id="getCategoryIdListByArticleId" resultType="integer">
        select category_id from tb_article_category where article_id = #{articleId}
    </select>
    <select id="getArticleIdListByCategoryId" resultType="integer">
        select article_id from tb_article_category where category_id = #{categoryId}
    </select>
    <insert id="saveArticleCategoryList">
        insert into tb_article_category(article_id, category_id) VALUES
        <foreach collection="articleCategoryList" item="category" separator=",">
            (#{category.articleId}, #{category.categoryId})
        </foreach>
    </insert>
    <delete id="deleteArticleCategoryByArticleId">
        delete from tb_article_category where article_id = #{articleId}
    </delete>
</mapper>