<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zeroxn.blog.mapper.CategoryMapper">
    <select id="getCategoryList" resultType="Category">
        select * from tb_category
        <if test="status != null">
            where status = #{status}
        </if>
        order by create_time
    </select>
    <insert id="addCategory">
        insert into tb_category(name, create_time) values (#{name}, #{createTime})
    </insert>
    <update id="updateCategoryStatus">
        update tb_category set status = #{status} where id = #{id}
    </update>
    <delete id="deleteCategory">
        delete from tb_category where id = #{id}
    </delete>
    <resultMap id="CategoryBashMap" type="Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
    </resultMap>
    <select id="getCategoryListByIdList" resultMap="CategoryBashMap">
        select id, name from tb_category where id in
        <foreach collection="categoryIdList" item="categoryId" separator="," open="(" close=")">
            #{categoryId}
        </foreach>
        and status = 1
    </select>
</mapper>